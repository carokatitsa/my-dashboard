<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cloud Planner Pro</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.1/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.1/firebase-database-compat.js"></script>
    
    <style>
        :root { --primary: #00b894; --bg: #091a28; --card: #162a3b; --text: #ecf0f1; }
        body { font-family: 'Segoe UI', sans-serif; background: var(--bg); color: var(--text); margin: 0; padding: 20px; }
        .container { max-width: 900px; margin: 0 auto; }
        .header-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 30px; }
        .stat-card { background: var(--card); padding: 20px; border-radius: 15px; text-align: center; border: 1px solid #2d4154; }
        .stat-card h3 { margin: 0; color: var(--primary); font-size: 2.5em; }
        .add-task { background: var(--card); padding: 20px; border-radius: 15px; display: flex; gap: 10px; margin-bottom: 20px; }
        input { border: 1px solid #2d4154; padding: 12px; border-radius: 8px; background: #091a28; color: white; outline: none; }
        input[type="text"] { flex: 3; }
        input[type="number"] { flex: 1; }
        button.add-btn { background: var(--primary); color: white; border: none; padding: 12px 25px; border-radius: 8px; cursor: pointer; font-weight: bold; }
        .task-list { background: var(--card); border-radius: 15px; overflow: hidden; }
        table { width: 100%; border-collapse: collapse; }
        th { background: #1c334a; padding: 15px; text-align: left; }
        td { padding: 15px; border-bottom: 1px solid #2d4154; }
        .chart-container { background: var(--card); padding: 20px; border-radius: 15px; margin-top: 30px; }
        .loading { text-align: center; padding: 20px; color: var(--primary); font-weight: bold; }
    </style>
</head>
<body>

<div class="container">
    <h1>☁️ Облачный Планер</h1>
    <div id="loadingStatus" class="loading">Подключение к базе данных...</div>

    <div class="header-stats">
        <div class="stat-card"><p>Твой опыт (XP)</p><h3 id="totalPoints">0</h3></div>
        <div class="stat-card"><p>Задач выполнено</p><h3 id="tasksToday">0</h3></div>
    </div>

    <div class="add-task">
        <input type="text" id="taskInput" placeholder="Какое действие добавим?">
        <input type="number" id="pointsInput" placeholder="XP" min="1">
        <button class="add-btn" onclick="addTask()">Добавить в облако</button>
    </div>

    <div class="task-list">
        <table>
            <thead><tr><th>Действие</th><th>Опыт</th><th>Статус</th></tr></thead>
            <tbody id="taskTableBody"></tbody>
        </table>
    </div>

    <div class="chart-container">
        <canvas id="progressChart"></canvas>
    </div>
</div>

<script>
    // ТВОИ НАСТРОЙКИ FIREBASE (Вставь свои данные из консоли!)
   const firebaseConfig = {
  apiKey: "AIzaSyA3QRDlZkS9-NnupC5KN65fMv1j39ZovsI",
  authDomain: "my-dashboard-dc67a.firebaseapp.com",
  projectId: "my-dashboard-dc67a",
  storageBucket: "my-dashboard-dc67a.firebasestorage.app",
  messagingSenderId: "710702954120",
  appId: "1:710702954120:web:f06b1038c48d3bd328913d",
  measurementId: "G-74720EWKSB"
};
    // Инициализация
    firebase.initializeApp(firebaseConfig);
    const db = firebase.database();
    const tasksRef = db.ref('tasks');

    let myChart;

    // Слушаем изменения в базе данных в реальном времени
    tasksRef.on('value', (snapshot) => {
        const data = snapshot.val();
        document.getElementById('loadingStatus').style.display = 'none';
        
        const tasksArray = [];
        for (let id in data) {
            tasksArray.push({ id, ...data[id] });
        }
        
        renderTasks(tasksArray);
        updateStats(tasksArray);
        updateChart(tasksArray);
    });

    function addTask() {
        const title = document.getElementById('taskInput').value;
        const pts = parseInt(document.getElementById('pointsInput').value);
        if(!title || !pts) return alert("Введите данные!");

        // Отправка в Firebase
        tasksRef.push({
            title: title,
            points: pts,
            completed: false,
            timestamp: Date.now(),
            date: new Date().toLocaleDateString()
        });

        document.getElementById('taskInput').value = '';
        document.getElementById('pointsInput').value = '';
    }

    function toggleTask(id, currentStatus) {
        db.ref('tasks/' + id).update({ completed: !currentStatus });
    }

    function deleteTask(id) {
        if(confirm("Удалить действие?")) db.ref('tasks/' + id).remove();
    }

    function renderTasks(tasks) {
        const body = document.getElementById('taskTableBody');
        // Показываем только невыполненные
        body.innerHTML = tasks.filter(t => !t.completed).map(t => `
            <tr>
                <td>${t.title}</td>
                <td><b style="color:var(--primary)">+${t.points} XP</b></td>
                <td>
                    <button onclick="toggleTask('${t.id}', false)" style="background:none; border:none; color:var(--primary); cursor:pointer; font-weight:bold;">DONE</button>
                    <button onclick="deleteTask('${t.id}')" style="background:none; border:none; color:#ff7675; cursor:pointer; margin-left:10px;">DEL</button>
                </td>
            </tr>
        `).join('');
    }

    function updateStats(tasks) {
        const completedTasks = tasks.filter(t => t.completed);
        const totalXP = completedTasks.reduce((sum, t) => sum + t.points, 0);
        document.getElementById('totalPoints').innerText = totalXP;
        document.getElementById('tasksToday').innerText = completedTasks.length;
    }

    function updateChart(tasks) {
        const ctx = document.getElementById('progressChart').getContext('2d');
        const dailyData = {};
        
        tasks.filter(t => t.completed).forEach(t => {
            dailyData[t.date] = (dailyData[t.date] || 0) + t.points;
        });

        if (myChart) myChart.destroy();
        myChart = new Chart(ctx, {
            type: 'bar', // Изменил на столбцы, так круче для баллов
            data: {
                labels: Object.keys(dailyData),
                datasets: [{
                    label: 'Заработано XP',
                    data: Object.values(dailyData),
                    backgroundColor: '#00b894',
                    borderRadius: 5
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { labels: { color: 'white' } } },
                scales: { 
                    y: { ticks: { color: 'white' } },
                    x: { ticks: { color: 'white' } }
                }
            }
        });
    }
</script>

</body>
</html>
